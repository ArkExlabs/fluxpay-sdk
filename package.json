{
  "name": "fluxpay-sdk",
  "version": "0.3.4",
  "description": "Headless Web3 payment SDK and UUPS payment processor for EVM-compatible chains.",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "abi",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./abi/FluxPayProcessor.v0.2.8.abi.json": "./abi/FluxPayProcessor.v0.2.8.abi.json",
    "./abi/FluxPayProcessor.v0.2.8.interface.json": "./abi/FluxPayProcessor.v0.2.8.interface.json"
  },
  "scripts": {
    "compile": "hardhat compile --force",
    "test": "hardhat test",
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build:clean": "npm run clean && npm run build",
    "abi:export": "hardhat run scripts/export-abi-snapshot.ts",
    "deploy:local": "hardhat run scripts/deploy-upgradeable.ts --network localhost",
    "verify:local": "hardhat run scripts/verify-deployment.ts --network localhost"
  },
  "keywords": [
    "web3",
    "payments",
    "sdk",
    "evm",
    "ethers",
    "uups",
    "crypto-payments"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "ethers": "^6.17.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.13",
    "@nomicfoundation/hardhat-ignition": "^3.1.7",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.7",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@openzeppelin/hardhat-upgrades": "^4.0.2",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "chai": "^6.2.2",
    "dotenv": "^17.2.3",
    "forge-std": "github:foundry-rs/forge-std#v1.9.4",
    "hardhat": "^3.9.0",
    "typescript": "~6.0.3",
    "viem": "^2.53.1"
  }
}
